---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Pixeleden | A Digital Garden & Journal of Allan Reyes',
  description = 'Tech and design blog of Allan Reyes. A digital product designer based in Madrid, Spain. Celebrating 20 years of pixels, craft and the open web.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/images/pixeleaf.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-eden-cream text-pixel-black pixel-grid min-h-screen flex flex-col">
    <slot />
  </body>
</html>
