---
interface Props {
  isHero?: boolean;
}

const { isHero = false } = Astro.props;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Journal', href: '/journal' },
  { label: 'Photography', href: '/photography' },
  { label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;

// Figma design assets
const pixeledenLogo = "http://localhost:3845/assets/ddfddae7fac8451983b90cd84d29892ddf8efa81.svg";
const pixeledenText = "http://localhost:3845/assets/e3a4723bfc84399aeb29dc5a126150caecba5dd1.svg";
---

{isHero ? (
  <!-- Hero Navigation (overlaid) -->
  <nav class="absolute top-[40px] left-[40px] right-[40px] z-50 bg-[rgba(72,101,67,0.16)] backdrop-blur-md flex items-center justify-between h-[104px] px-6 py-6 rounded-[40px] shadow-[0px_4px_24px_4px_rgba(0,0,0,0.25)]">
    <!-- Logo section -->
    <div class="flex items-center gap-[13px] flex-1">
      <img
        src={pixeledenLogo}
        alt="Pixeleden"
        class="h-[54px] w-[71px] object-contain"
      />
      <img
        src={pixeledenText}
        alt=""
        class="h-[46px] w-[209px] object-contain"
      />
    </div>

    <!-- Desktop nav items -->
    <ul class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'text-2xl font-display text-white transition-opacity duration-150',
              currentPath === item.href ? 'font-bold' : 'font-normal opacity-90 hover:opacity-100',
            ]}
            style={{ fontVariationSettings: "'CTGR' 100, 'wdth' 100" }}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-white"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>
) : (
  <!-- Standard sticky header -->
  <header class="sticky top-0 z-50 bg-eden-cream/90 backdrop-blur-md border-b border-eden-green-100">
    <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group" aria-label="Pixeleden Home">
        <img
          src="/images/pixeleaf.svg"
          alt=""
          class="w-8 h-8 transition-transform duration-300 group-hover:rotate-12"
        />
        <span class="font-serif text-xl text-eden-green-600 tracking-tight">
          pixel<span class="text-eden-leaf">eden</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'px-4 py-2 text-sm font-mono tracking-wide transition-colors duration-150 rounded-sm',
                currentPath === item.href
                  ? 'text-eden-green-600 bg-eden-green-50'
                  : 'text-pixel-gray-500 hover:text-eden-green-600 hover:bg-eden-green-50/50',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-pixel-gray-500 hover:text-eden-green-600"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="md:hidden hidden border-t border-eden-green-100">
      <ul class="px-4 py-3 space-y-1">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'block px-4 py-2.5 text-sm font-mono tracking-wide rounded-sm transition-colors',
                currentPath === item.href
                  ? 'text-eden-green-600 bg-eden-green-50'
                  : 'text-pixel-gray-500 hover:text-eden-green-600 hover:bg-eden-green-50/50',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </header>
)}

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
